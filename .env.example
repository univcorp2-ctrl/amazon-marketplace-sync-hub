# Runtime
APP_MODE=demo
API_LIVE_ENABLED=false
ENABLE_BACKGROUND_SYNC=false
DATABASE_URL=sqlite:///./data/app.db
CORS_ORIGINS=*

# Amazon Selling Partner API (Japan)
AMAZON_LWA_CLIENT_ID=
AMAZON_LWA_CLIENT_SECRET=
AMAZON_REFRESH_TOKEN=
AMAZON_SP_API_ENDPOINT=https://sellingpartnerapi-fe.amazon.com
AMAZON_MARKETPLACE_ID=A1VC38T7YXB528
AMAZON_CACHE_TTL_SECONDS=300

# Shopee Open Platform
SHOPEE_PARTNER_ID=0
SHOPEE_PARTNER_KEY=
SHOPEE_SHOP_ID=0
SHOPEE_ACCESS_TOKEN=
SHOPEE_BASE_URL=https://partner.shopeemobile.com
SHOPEE_DEFAULT_CATEGORY_ID=0
SHOPEE_LOGISTIC_INFO=[]

# Qoo10 QAPI
QOO10_API_KEY=
QOO10_USER_ID=
QOO10_PASSWORD=
QOO10_BASE_URL=https://api.qoo10.jp
QOO10_DEFAULT_CATEGORY_ID=
QOO10_SHIPPING_NO=0
QOO10_CONTACT_TEL=
QOO10_PRODUCTION_PLACE=Japan

# Pricing / safety stock
PRICE_MARKUP=1.18
PRICE_FIXED_FEE=300
MINIMUM_MARGIN=300
STOCK_BUFFER_QUANTITY=2
SYNC_INTERVAL_SECONDS=900
RIGHTS_CONFIRMATION_REQUIRED=true

# Cloudflare Pages build-time optional backend URL
PUBLIC_API_BASE_URL=
